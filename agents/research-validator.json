{
  "name": "research-validator",
  "description": "Research validator agent. Ensures output from the researcher are all accurate.",
  "prompt": "You are a research validator. Review findings from the researcher for accuracy and completeness.\n\nFor each claim in the researcher's output:\n1. Identify the cited source URL.\n2. If no source URL is cited, mark the claim UNVERIFIED — do not pass it forward.\n3. Verify the claim is consistent with the cited source (re-fetch with firecrawl_scrape if needed).\n4. Classify each finding: CONFIRMED | UNVERIFIED | CONTRADICTED.\n\nOutput a validation report grouped by classification:\n- CONTRADICTED: claims that conflict with their cited source (list first, must be fixed)\n- UNVERIFIED: claims with no citation or unreachable source\n- CONFIRMED: claims verified against source\n\nDo NOT pass any finding forward that lacks direct evidence from a cited source.",
  "tools": ["read", "shell", "@firecrawl", "@sequential-thinking"],
  "allowedTools": [
    "read",
    "shell",
    "@firecrawl/firecrawl_scrape",
    "@firecrawl/firecrawl_search",
    "@firecrawl/firecrawl_map",
    "@firecrawl/firecrawl_extract",
    "@firecrawl/firecrawl_crawl",
    "@firecrawl/firecrawl_check_crawl_status",
    "@firecrawl/firecrawl_agent",
    "@firecrawl/firecrawl_agent_status",
    "@sequential-thinking/sequentialthinking"
  ],
  "mcpServers": {
    "obsidian": {
      "command": "npx",
      "args": [
        "-y",
        "@mauricio.wolff/mcp-obsidian@latest",
        "~/Documents/work"
      ],
      "autoApprove": [
        "write_note",
        "list_directory",
        "search_notes",
        "read_note",
        "patch_note"
      ],
      "disabledTools": [
        "move_note",
        "move_file",
        "update_frontmatter",
        "manage_tags",
        "get_vault_stats"
      ]
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_URL": "http://localhost:3002"
      },
      "autoApprove": [
        "firecrawl_scrape",
        "firecrawl_map",
        "firecrawl_search",
        "firecrawl_extract"
      ],
      "disabledTools": [
        "firecrawl_browser_create",
        "firecrawl_browser_execute",
        "firecrawl_browser_delete",
        "firecrawl_browser_list"
      ]
    }
  },
  "toolsSettings": {
    "shell": {
      "timeout": 30000,
      "allowedCommands": [
        "curl *",
        "wget *",
        "git log",
        "git show",
        "cat",
        "head",
        "tail",
        "find",
        "grep",
        "@firecrawl/firecrawl_scrape",
        "@firecrawl/firecrawl_search",
        "@firecrawl/firecrawl_map",
        "@firecrawl/firecrawl_extract",
        "@firecrawl/firecrawl_crawl",
        "@firecrawl/firecrawl_check_crawl_status",
        "@firecrawl/firecrawl_agent",
        "@firecrawl/firecrawl_agent_status",
        "@sequential-thinking/sequentialthinking"
      ]
    }
  },
  "model": "claude-sonnet-4-6",
  "permissionMode": "dontAsk"
}
